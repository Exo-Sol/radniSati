\src\\seconPage\\components2\\MainDiv.js":"24","C:\\Users\\Exo\\Desktop\\radni-sati\\src\\seconPage\\components2\\NukeStorage.js":"25","C:\\Users\\Exo\\Desktop\\radni-sati\\src\\seconPage\\components2\\Delete.js":"26","C:\\Users\\Exo\\Desktop\\radni-sati\\src\\components\\HList.js":"27","C:\\Users\\Exo\\Desktop\\radni-sati\\src\\components\\PopUp.js":"28","C:\\Users\\Exo\\Desktop\\radni-sati\\src\\seconPage\\components2\\childs\\DateChild.js":"29","C:\\Users\\Exo\\Desktop\\radni-sati\\src\\seconPage\\components2\\childs\\TemplateChild.js":"30"},{"size":198,"mtime":1612353468344,"results":"31","hashOfConfig":"32"},{"size":2417,"mtime":1613644437470,"results":"33","hashOfConfig":"32"},{"size":5854,"mtime":1613664404703,"results":"34","hashOfConfig":"32"},{"size":2638,"mtime":1613041401678,"results":"35","hashOfConfig":"32"},{"size":364,"mtime":1612357701466,"results":"36","hashOfConfig":"32"},{"size":815,"mtime":1611830727444,"results":"37","hashOfConfig":"32"},{"size":845,"mtime":1613063226541,"results":"38","hashOfConfig":"32"},{"size":6663,"mtime":1613590929675,"results":"39","hashOfConfig":"32"},{"size":4375,"mtime":1613665177530,"results":"40","hashOfConfig":"32"},{"size":1989,"mtime":1612986874319,"results":"41","hashOfConfig":"32"},{"size":362,"mtime":1612983354825,"results":"42","hashOfConfig":"32"},{"size":1041,"mtime":1613060752924,"results":"43","hashOfConfig":"32"},{"size":3438,"mtime":1613481786115,"results":"44","hashOfConfig":"32"},{"size":563,"mtime":1613591350011,"results":"45","hashOfConfig":"32"},{"size":381,"mtime":1613650690415,"results":"46","hashOfConfig":"32"},{"size":347,"mtime":1613666482785,"results":"47","hashOfConfig":"48"},{"size":2417,"mtime":1613644437470,"results":"49","hashOfConfig":"48"},{"size":6663,"mtime":1613590929675,"results":"50","hashOfConfig":"48"},{"size":4375,"mtime":1613665177530,"results":"51","hashOfConfig":"48"},{"size":381,"mtime":1613650690415,"results":"52","hashOfConfig":"48"},{"size":845,"mtime":1613063226541,"res